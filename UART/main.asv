data = readmatrix('NewFile1.csv', 'NumHeaderLines', 2);
dt = 2e-6; 
t = data(:,1)*dt;
v = data(:,2);

plot(t,v)
grid on
xlabel('Time (s)')
ylabel('Voltage (V)')


thresh = 2.75;
data_payload = zeros(1,8);

index = 1;

interval = round((1/9600)/dt)

while (v(index) >= thresh)
    index = index + 1;
end
index = index + round(interval* 3/2);
for k = 1:8
    data_payload(k) = v(index) > thresh